@model Category

@{
	ViewData["Title"] = "CategoryEdit";
	Layout = "~/Views/Shared/AdminLayout.cshtml";
}


<div class="row yukaribosluk">

	<div class="col-md-2 "></div>

	<div class="col-md-8 ">

		<!-- BEGIN SAMPLE FORM PORTLET-->
		<div class="portlet box purple ">
			<div class="portlet-title">
				<div class="caption">
					<i class="fa fa-gift"></i> KATEGORİ GÜNCELLEME FORMU
				</div>
				<div class="tools">
					<a href="" class="collapse">
					</a>
					<a href="#portlet-config" data-toggle="modal" class="config">
					</a>
					<a href="" class="reload">
					</a>
					<a href="" class="remove">
					</a>
				</div>
			</div>
			<div class="portlet-body form">
				<form class="form-horizontal" role="form" action="/Admin/CategoryEdit" method="post">
					@Html.AntiForgeryToken()

					<div class="form-body">

						<div class="form-group">
							<label class="col-md-3 control-label">
								@Html.DisplayNameFor(model => model.ParentID)
							</label>
							<div class="col-md-9">

								@Html.DropDownList("ParentID", (IEnumerable<SelectListItem>)ViewData["categoryList"]!, "Seçiniz", new { @class = "form-control input-lg" })
							</div>
						</div>


						<div class="form-group">
							<label class="col-md-3 control-label">
								@Html.DisplayNameFor(model => model.CategoryName)
							</label>
							<div class="col-md-9">
								<input type="text" class="form-control input-lg" placeholder="" asp-for="CategoryName">
							</div>
						</div>



						<div class="form-group">
							<label class="col-md-3 control-label">
								@Html.DisplayNameFor(model => model.Active)
							</label>
							<div class="col-md-9">
								<input asp-for="Active" class="form-control input-sm" />
								<span asp-validation-for="Active" class="text-danger"></span>
							</div>
						</div>

						<input type="hidden" asp-for="CategoryID" />

					</div>

					<div class="form-actions right1">
						<a asp-action="CategoryIndex" class="btn btn-primary">KATEGORİ LİSTESİ</a>
						<input type="submit" name="name" value="GÜNCELLE" class="btn btn-primary" />
					</div>

				</form>
			</div>
		</div>
		<!-- END SAMPLE FORM PORTLET-->


	</div>
</div>