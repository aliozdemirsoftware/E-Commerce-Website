@model Setting

@{
    ViewData["Title"] = "SettingEdit";
    Layout = "~/Views/Shared/AdminLayout.cshtml";
}


<!-- BEGIN PAGE CONTENT-->
<div class="row">

    <div class="col-md-2"></div>

    <div class="col-md-8 ">
        <!-- BEGIN SAMPLE FORM PORTLET-->
        <div class="portlet box purple ">
            <div class="portlet-title">
                <div class="caption">
                    <i class="fa fa-gift">AYAR GÜNCELLEME FORMU</i>
                </div>
                <div class="tools">
                    <a href="" class="collapse">
                    </a>
                    <a href="#portlet-config" data-toggle="modal" class="config">
                    </a>
                    <a href="" class="reload">
                    </a>
                    <a href="" class="remove">
                    </a>
                </div>
            </div>
            <div class="portlet-body form">
                <form class="form-horizontal" role="form" action="/Admin/SettingEdit" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                    <div class="form-body">

                        <div class="form-group">
                            <label class="col-md-3 control-label">
                                @Html.DisplayNameFor(model => model.Telephone)
                            </label>
                            <div class="col-md-9">
                                <input asp-for="Telephone" class="form-control input-lg" placeholder="Telefon" required maxlength="100" onkeypress="return numberonly(this, event);" />
                            </div>
                            <span asp-validation-for="Telephone" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="col-md-3 control-label">
                                @Html.DisplayNameFor(model => model.Email)
                            </label>
                            <div class="col-md-9">
                                <input asp-for="Email" class="form-control input-lg" placeholder="Email" required />
                            </div>
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>


                        <div class="form-group">
                            <label class="col-md-3 control-label">
                                @Html.DisplayNameFor(model => model.Address)
                            </label>
                            <div class="col-md-9">
                                <input asp-for="Address" class="form-control input-lg" placeholder="Stok" required />
                            </div>
                            <span asp-validation-for="Address" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="col-md-3 control-label">
                                @Html.DisplayNameFor(model => model.MainpageCount)
                            </label>
                            <div class="col-md-9">
                                <input asp-for="MainpageCount" class="form-control input-lg" placeholder="" />
                            </div>
                            <span asp-validation-for="MainpageCount" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="col-md-3 control-label">
                                @Html.DisplayNameFor(model => model.SubpageCount)
                            </label>
                            <div class="col-md-9">
                                <input asp-for="SubpageCount" class="form-control input-lg" placeholder="" />
                            </div>
                            <span asp-validation-for="SubpageCount" class="text-danger"></span>
                        </div>


                        <input type="hidden" asp-for="SettingID" />

                    </div>
                    <div class="form-actions right1">
                        <a asp-action="SettingIndex" class="btn btn-primary">AYAR LİSTESİ</a>
                        <input type="submit" name="name" value="GÜNCELLE" class="btn btn-success" />
                    </div>
                </form>
            </div>
        </div>
        <!-- END SAMPLE FORM PORTLET-->
    </div>
</div>
<!-- END PAGE CONTENT-->