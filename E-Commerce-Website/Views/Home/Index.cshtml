	<div class="container">
		<div class="row">
			<div class="col-sm-12 col-md-12 col-lg-12 ">
				<div class="n-full-products">
					<div class="all-p-title">
						<h3 style="background-color:darkorange;font-style:italic; color:black;">DİKKAT ÇEKENLER</h3>
					</div>
					<div class="row">
						<div class="all-new-p">
							<div class="all-new-single singal-p hom-1">

								@foreach (var item in Model.NotableProducts)
								{
									<!-- SP-SINGLE Product -->
									<div class="col-sm-12 col-md-12 col-lg-12">
										<div class="sp-single">
											<div class="sp-img-area">
												<img class="first-img" src="/img/resimler/@item.PhotoPath" alt="" style="height:200px" />
												<img class="hover-img" src="/img/resimler/@item.PhotoPath" alt="" style="height:200px" />
												<div class="quick-view-detail">
													<a href="/Home/Details/@item.ProductID">Detaylar</a>
												</div>
												<div class="sp-label-pro sp-label-pro-hot" style="background-color:darkmagenta; color:black; height:40px;width:40px;border-radius:50%;font-size:25px; display:flex; align-items:center; justify-content:center; text-align:center;">&star;</div>
											</div>
											<div class="sp-info-area">
												<h2 class="product-name"><a title="@item.Notes" href="/Home/Details/@item.ProductID">@item.ProductName</a></h2>
												<div class="product-rating">
													<div class="ratingbox" title="" Rating="3/5">
														<div style="width:50px" class="stars-orange"></div>
													</div>
												</div>
												<p class="all-prices">
													<span class="sp-price main-price">@item.UnitPrice TL</span>
												</p>
												<div class="sp-button">
													<div class="s-button">
														<a href="/Home/CartProcess/@item.ProductID" data-toggle="tooltip" data-placement="top" title="Sepete Ekle" class="black-tooltip add-to-cart all_src_icon"> <i class="fa fa-shopping-cart"></i> </a>
													</div>
													<div class="s-button">
														<a data-toggle="tooltip" data-placement="top" class="black-tooltip add-to-cart all_src_icon"></a>
													</div>
													<div class="s-button last-b ">
														<a href="index.html#" data-toggle="tooltip" data-placement="top" title="view detail" class="black-tooltip add-to-cart all_src_icon"> <i class="fa fa-eye"></i> </a>
													</div>
												</div>
											</div>
										</div>
									</div>
								}

							</div>
						</div>

					</div>
				</div>
			</div>
		</div>
	</div>
</div>
