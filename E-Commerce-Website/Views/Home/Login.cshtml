@model User

@{
    ViewData["Title"] = "Login";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

@* Create an New Account *@
<div class="loging-areas">
    <div class="container">
        <div class="row">
            <div class="col-sm-12 col-md-6 col-lg-3"></div>

            <div class="col-sm-12 col-md-6 col-lg-6">
                <div class="login-users" style="margin-top:50px;">
                    <form action="/Home/Login" id="com-form-login" method="post">

                        <!--trafik konrolü yapar-güvenlik amaçlı-->
                        @Html.AntiForgeryToken()

                        <fieldset class="userdata content" style="border-color:black;">
                            <h2>GİRİŞ YAPINIZ</h2>
                            <ul class="form-list">
                                <li>
                                    <label class="required"><em>*</em>E-Mail</label>
                                    <div class="input-box" id="com-form-login-username">
                                        <input type="text" class="inputbox" asp-for="Email">
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                </li>
                                <li>
                                    <label class="required"><em>*</em>Şifre</label>
                                    <div class="input-box" id="com-form-login-username">
                                        <input type="password" class="inputbox" asp-for="Password">
                                        <span asp-validation-for="Password" class="text-danger"></span>
                                    </div>
                                </li>

                                <input type ="hidden" asp-for="NameSurname" value="for-Required"/>
                                <input type="hidden" asp-for="Telephone" value="for-Required" />

                            </ul>
                        </fieldset>
                        <div class="submit_crt">
                            <input type="submit" value="GİRİŞ YAP" class="update_cart" name="Submit">
                        </div>
                    </form>
                </div>
            </div>

        </div>
    </div>
</div>
