@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<Product>

@{
    ViewData["Title"] = "TopsellerProducts";
    Layout = "~/Views/Shared/DefaultLayout.cshtml";
}

<!-- Single product area start  -->
<div class="shop-wrapper">
    <div class="container">
        <div class="row">
            <div class="col-sm-9 col-md-9 col-lg-12">
                <div class="row">
                    <div class="col-sm-12 col-md-12 col-lg-12">
                        <div class="rp-area">
                            <div class="singl-shop ">
                                <div class="row">
                                    @*<span style="text-align:center;">
                                        <pager list="@Model" asp-controller="Home" asp-action="TopsellerProducts"></pager>
                                        </span>*@
                                    


                                    @foreach (var item in Model)
                                    {
                                        <!-- SP-SINGLE Product -->
                                        <div class="col-sm-3 col-md-3 col-lg-3">
                                            <div class="sp-single">
                                                <div class="sp-img-area">
                                                    <img class="first-img" src="~/img/resimler/@item.PhotoPath" alt="" style="height:200px;width:200px;" />
                                                    <img class="hover-img" src="~/img/resimler/@item.PhotoPath" alt="" style="height:200px;width:200px;" />
                                                    <div class="quick-view-detail">
                                                        <a href="/Home/Details/@item.ProductID">Detaylar</a>
                                                    </div>
                                                    <div class="sp-label-pro sp-label-pro-hot" style="background-color:#7469B6 ; color: white;">TALEP</div>
                                                </div>
                                                <div class="sp-info-area">
                                                    <h2 class="product-name"><a title="@item.ProductName" href="/Home/Details/@item.ProductID">@item.ProductName </a></h2>
                                                    <p class="all-prices">
                                                        <span class="sp-price main-price">@item.UnitPrice TL</span>
                                                    </p>
                                                    <div class="sp-button">
                                                        <div class="s-button">
                                                            <a href="/Home/CartProcess/@item.ProductID" data-toggle="tooltip" data-placement="top" title="Sepete Ekle" class="black-tooltip add-to-cart all_src_icon"> <i class="fa fa-shopping-cart"></i> </a>
                                                        </div>
                                                        <div class="s-button">
                                                            <a href="" data-toggle="tooltip" data-placement="top" title="" class="black-tooltip add-to-cart all_src_icon">  </a>
                                                        </div>
                                                        <div class="s-button last-b ">
                                                            <a href="/Home/Details/@item.ProductID" data-toggle="tooltip" data-placement="top" title="Detaylar" class="black-tooltip add-to-cart all_src_icon"> <i class="fa fa-eye"></i> </a>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    }

                                    <!--Bootstrap pagination -->
                                    <style>
    .pagination .page-link {
        color: #ff7a00;
        border-color: #ff7a00;
    }

    .pagination .page-link:hover {
        background-color: #ff7a00;
        color: #fff;
        border-color: #ff7a00;
    }

    .pagination .page-item.active .page-link {
        background-color: #ff7a00;
        border-color: #ff7a00;
        color: #fff;
    }

    .pagination .page-item.disabled .page-link {
        color: #ffc08a;
        border-color: #ffc08a;
    }
</style>

<span>
    <nav aria-label="Sayfa gezinme">
        <ul class="pagination justify-content-center">
            <li class="page-item @(Model.HasPreviousPage ? "" : "disabled")">
                <a class="page-link"
                   href="@(Model.HasPreviousPage ? Url.Action("TopsellerProducts", new { page = Model.PageNumber - 1 }) : "#")"
                   aria-label="Önceki">
                    <span aria-hidden="true">&laquo;</span>
                </a>
            </li>

            @for (int i = 1; i <= Model.PageCount; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link"
                       href="@Url.Action("TopsellerProducts", new { page = i })">
                        @i
                    </a>
                </li>
            }

            <li class="page-item @(Model.HasNextPage ? "" : "disabled")">
                <a class="page-link"
                   href="@(Model.HasNextPage ? Url.Action("TopsellerProducts", new { page = Model.PageNumber + 1 }) : "#")"
                   aria-label="Sonraki">
                    <span aria-hidden="true">&raquo;</span>
                </a>
            </li>
        </ul>
    </nav>
</span>

                                    
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
<!--Single product area End  -->